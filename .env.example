# ---------------------------------------------------------------------------
# LicitScope – root environment variables (copy to .env for local development)
# ---------------------------------------------------------------------------

# --- API ---
APP_ENV=development
APP_NAME=LicitScope
APP_LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# --- Database ---
# In Docker compose, this resolves to the postgres service.
# For pure-local SQLite mode, set DATABASE_URL=sqlite:///./licitscope.db
DATABASE_URL=postgresql+psycopg://licitscope:licitscope@db:5432/licitscope

# --- Ingestion ---
# PNCP is the Portal Nacional de Contratações Públicas (https://pncp.gov.br).
# These endpoints are public; no API key is required.
PNCP_BASE_URL=https://pncp.gov.br/api/consulta
INGESTION_USE_FIXTURES=true       # if true, ingestion uses bundled snapshot
INGESTION_PAGE_SIZE=50
INGESTION_MAX_PAGES=5
INGESTION_REQUEST_TIMEOUT=30

# --- Enrichment ---
# Offline (heuristic) is the default. Set LLM_PROVIDER to enable optional LLM calls.
ENRICHMENT_MODE=offline            # offline | llm
LLM_PROVIDER=                      # anthropic | openai | (empty = none)
LLM_API_KEY=
LLM_MODEL=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
